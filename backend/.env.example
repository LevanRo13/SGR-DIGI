# ============================================
# AURA SGR - Variables de Entorno (Backend)
# Copiar este archivo como .env y completar valores
# ============================================

# --- Gemini AI ---
# Obtener en: https://aistudio.google.com/apikey
# Modelos disponibles 2026 (Free Tier):
#   - gemini-2.5-flash-lite: 1000 req/día, rápido para docs simples
#   - gemini-2.5-flash: equilibrado, recomendado
#   - gemini-2.5-pro: 50 req/día, para docs complejos
GEMINI_API_KEY=tu_api_key_de_gemini
GEMINI_MODEL=gemini-2.5-flash

# --- Stellar Blockchain (Legacy Horizon - deprecado) ---
# STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# --- Stellar Soroban (Smart Contracts) ---
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
STELLAR_SECRET_KEY=tu_secret_key_stellar

# --- Soroban Contract IDs ---
GUARANTEE_TOKEN_CONTRACT_ID=CBXXX... # ID del contrato GuaranteeToken
MARKETPLACE_CONTRACT_ID=CAXXX...     # ID del contrato Marketplace

# --- Server ---
PORT=3000
